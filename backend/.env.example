# Copy to backend/.env and fill in. .env is gitignored — never commit real secrets.

# Supabase Postgres connection string (use the Session/Transaction pooler URI).
# Project -> Settings -> Database -> Connection string -> URI (Transaction pooler)
DATABASE_URL=postgresql://postgres.<ref>:PASSWORD@aws-0-<region>.pooler.supabase.com:6543/postgres

# CORS: the frontend origin allowed to call this API.
FRONTEND_ORIGIN=http://localhost:3000

# Supabase Auth
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=<publishable key>        # Project -> Settings -> API -> publishable/anon key
SUPABASE_SERVICE_KEY=<secret key>          # Project -> Settings -> API -> secret/service_role key (backend only!)
